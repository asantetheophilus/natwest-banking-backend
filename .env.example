# ═══════════════════════════════════════════════════
# NatWest Banking Backend — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (MySQL) ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=natwest_bank

# ─── JWT Authentication ──────────────────────────
# CRITICAL: Change this to a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_to_a_64_char_random_string
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Examples:
#   Single: http://localhost:3000
#   Multiple: http://localhost:3000,https://myapp.com
FRONTEND_URL=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────
# General API rate limit (requests per 15-minute window)
JWT_SECRET=mysecretkey123456789
RATE_LIMIT_MAX=100

# Auth endpoints get a stricter limit (per 15-minute window)
AUTH_RATE_LIMIT_MAX=20

# ─── Transfer Approval Threshold ──────────────────
# Transfers >= this amount (GBP) require admin approval
APPROVAL_THRESHOLD=5000
